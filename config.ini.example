; =============================================================================
; QINGLV 光选分拣系统主配置文件 config.ini
;
; 加载入口:
;   * 主链路 RuntimeConfig - src/config/runtime_config.cpp::loadRuntimeConfig
;     读 [camera/model/yolo/pipeline/belt/sorter/valve/arm_stub/persistence] 八段;
;     sessionStart 通过 Q_ARG(RuntimeConfig) 值拷贝下发到 5 个 worker。
;   * UI 文案/语言 - src/app/mainwindow.cpp 在构造时读 [colorButtons /
;     categoryButtons / labelButtons / shapeButtons / appearanceButtons /
;     config/language] 装配按钮组与界面语言;[SelectedButtons]/names 由
;     startSession 读出 -> 合成 RuntimeConfig::enabledClassIds(F13 触发前过滤)。
;   * Legacy   - [OSS] 由 src/legacy/uploadpictooss.* 读取,主链路不依赖,
;                配置缺失/错误不会影响 Running 态业务。
;
; 编码: UTF-8 (QSettings::setIniCodec("UTF-8"))。中文可用 \xHHHH 转义,
;       也可以直接写 UTF-8 字符。
; 注释: ';' 与 '#' 均为行注释;本文件统一把注释写在 key 上一行,不写行内,
;       避免任何解析歧义(尤其与 unicode 转义 \xHHHH 共行时)。
; 默认: 注释中标注的 default=... 是 src/config/runtime_config.h 内置默认值,
;       INI 缺该 key 时回落到此值。
; 详细: 见 docs/architecture.md §4 配置层(全量参数对照表)。
; =============================================================================


; -----------------------------------------------------------------------------
; [colorButtons]  UI "颜色"按钮文案 (F3,纯 UI,不进算法)
; 由 createButtonsFromini("colorButtons", ...) 装配。值是按钮显示文案,
; 中文用 \xHHHH 转义,英文文案由 i18n/*.qm 翻译。
; -----------------------------------------------------------------------------
[colorButtons]
white=\x767d\x8272
green=\x7eff\x8272
blue=\x84dd\x8272
yellow=\x9ec4\x8272
black=\x9ed1\x8272
transparent=\x900f\x660e
transparentwhite=\x534a\x900f\x660e\x767d
mixedcolor=\x6df7\x8272


; -----------------------------------------------------------------------------
; [categoryButtons]  UI "材质/品类"按钮文案 (F3 — 主品类)
; 与 [model] 段下 class_btn/N/name 一一对应:勾选后由
; refreshEnabledClassIdsFromUi 把 name -> class_id 写入 enabledClassIds,
; 只有这些 id 才会触发 SortTask。
; -----------------------------------------------------------------------------
[categoryButtons]
plasticbottle=\x5851\x6599\x74f6
beveragebottle=\x996e\x6599\x74f6
oilsaucebottle=\x6cb9\x9171\x74f6
babybottle=\x5976\x74f6
aluminumcan=\x94dd\x7f50
tetrapak=\x5229\x4e50\x5305
plasticcup=\x5851\x6599\x676f
takeoutbox=\x5916\x5356\x76d2
widemouthjar=\x5e7f\x53e3\x74f6


; -----------------------------------------------------------------------------
; [labelButtons]   UI "标签类型"按钮文案 (F3,纯 UI,不进算法)
; -----------------------------------------------------------------------------
[labelButtons]
nolabel=\x65e0\x6807\x7b7e
rolllabel=\x5377\x6807
sticker=\x8d34\x6807
directprint=\x76f4\x63a5\x5370\x5237


; -----------------------------------------------------------------------------
; [shapeButtons]   UI "外形"按钮文案 (F3,纯 UI,不进算法)
; -----------------------------------------------------------------------------
[shapeButtons]
round=\x5706\x5f62
square=\x65b9\x5f62
irregular=\x4e0d\x89c4\x5219
flat=\x6241\x5e73
longneck=\x957f\x9888


; -----------------------------------------------------------------------------
; [appearanceButtons]  UI "外观状态"按钮文案 (F3,纯 UI,不进算法)
; -----------------------------------------------------------------------------
[appearanceButtons]
clean=\x5e72\x51c0
dirty=\x6c61\x6e0d
damaged=\x7834\x635f
compressed=\x538b\x6241
foreignmatter=\x5f02\x7269


; -----------------------------------------------------------------------------
; [SelectedButtons]  UI 上次勾选记忆 (F3 联动 enabledClassIds)
;   names: 逗号分隔的按钮 key 列表(取 [categoryButtons] / [labelButtons] /
;          [shapeButtons] / [appearanceButtons] 等段的 key);
;          startSession 读出后转 class_id 集合写入 enabledClassIds。
; -----------------------------------------------------------------------------
[SelectedButtons]
names=widemouthjar, nolabel


; -----------------------------------------------------------------------------
; [OSS]  阿里云 OSS 凭证 (legacy,主链路不依赖)
; 由 src/legacy/uploadpictooss.* 上传时读取。生产环境不需要 OSS 时,
; 这里保留占位字符串,既不会影响业务,也不会触发 OSS 上传。
; 注意:真实部署请改成自有凭证并不要把私钥提交进版本库!
; -----------------------------------------------------------------------------
[OSS]
; OSS 服务端域名(完整 URL)
endpoint=https://oss-cn-hangzhou.aliyuncs.com
; AccessKey ID(占位 LTAIxxxxxxxxxxxx)
accessKeyId=LTAIxxxxxxxxxxxx
; AccessKey Secret(占位 xxxxxxxxxxxxxxxxxxxxx,生产请改)
accessKeySecret=xxxxxxxxxxxxxxxxxxxxx
; OSS Bucket 名
bucketName=my-image-bucket


; -----------------------------------------------------------------------------
; [config]  UI 全局开关
; -----------------------------------------------------------------------------
[config]
; UI 显示语言: chinese | english。
; MainWindow::on_languageButton_clicked 切换时会写回此键(持久化用户选择)。
language=chinese


; -----------------------------------------------------------------------------
; [camera]  海康 GigE 相机参数 (消费方:CameraWorker, TrackerWorker)
; 物理像素 -> 物理 mm 的换算依赖 real_length_mm / real_width_mm,
; TrackerWorker::rasterizeToBelt 用它把检测 bbox/mask 转到 belt 系。
; -----------------------------------------------------------------------------
[camera]
; 相机 IP. CameraWorker::probeConnection 用于硬连通检查;default=192.168.1.30
ip=192.168.1.30
; 硬件层最大帧率 fps. 实际吐到下游的节流帧率由 [pipeline] soft_fps 决定;
; default=60
hw_fps=60
; 是否纵向翻转图像(部分安装方向相反的机器使用);default=false
y_flip=false
; 视野 X 方向(图像列方向)对应物理宽度 mm. 喷阀阵列横向覆盖 = x_max-x_min,
; 通常与本字段同量级;default=560
real_length_mm=560
; 视野 Y 方向(图像行方向 = 皮带前进方向)对应物理长度 mm. 影响 bbox 在
; belt 系的纵向位置 + extrapolateBbox 位移补偿;default=470
real_width_mm=470


; -----------------------------------------------------------------------------
; [model]  RKNN 模型与品类映射表 (消费方:YoloWorker, MainWindow UI)
; YoloWorker::preloadModel 在进程启动即加载;sessionStart 时仅当 path 变化
; 才 release+reload。下方 class_btn 是 模型 class_id <-> UI 按钮 key 的
; 映射,refreshEnabledClassIdsFromUi 用 name 反查 id。
; -----------------------------------------------------------------------------
[model]
; .rknn 模型路径(板上绝对路径);default=/opt/models/yolov8seg.rknn
path=/opt/models/yolov8seg.rknn
; 模型输入边长(letterbox 目标尺寸);yolov8-seg 通常 1024 或 640. default=1024
input_size=1024
; 兼容 top-k 输出布局的 class 总数兜底(模型 head 元信息缺失时用). default=80
topk_class_count=80
; 品类按钮表 size:下方 class_btn/N/{name,id} 的项数 N
class_btn/size=9
; 第 N 项的按钮 key(对应 [categoryButtons] 段同名 key)与模型类别 id;
; refreshEnabledClassIdsFromUi 用 name 反查 id 合入 enabledClassIds
class_btn/1/name=plasticbottle
class_btn/1/id=0
class_btn/2/name=beveragebottle
class_btn/2/id=1
class_btn/3/name=oilsaucebottle
class_btn/3/id=2
class_btn/4/name=babybottle
class_btn/4/id=3
class_btn/5/name=aluminumcan
class_btn/5/id=4
class_btn/6/name=tetrapak
class_btn/6/id=5
class_btn/7/name=plasticcup
class_btn/7/id=6
class_btn/8/name=takeoutbox
class_btn/8/id=7
class_btn/9/name=widemouthjar
class_btn/9/id=8


; -----------------------------------------------------------------------------
; [yolo]  推理后处理参数 (消费方:YoloWorker, postprocess_ex)
; -----------------------------------------------------------------------------
[yolo]
; 置信度过滤阈值. Phase 1 候选扫描时 score < conf_threshold 直接丢. default=0.25
conf_threshold=0.25
; NMS IoU 阈值. Phase 2 per-class + Phase 2.5 cross-class 都复用同一阈值.
; default=0.45
nms_threshold=0.45
; 是否给 UI 发带 mask/box/label 的 overlay 图(F5 可视化). 关闭可省 ~5ms/帧;
; default=true
draw_overlay=true


; -----------------------------------------------------------------------------
; [pipeline]  跨 worker 共享的核心节奏与跟踪参数
; (消费方:CameraWorker / TrackerWorker / BoardWorker)
; -----------------------------------------------------------------------------
[pipeline]
; 软节流帧率 fps. CameraWorker::onTick 周期 = 1000/soft_fps ms. default=2
soft_fps=2
; F13 跨帧关联打分阈值. score = max(maskIoU, maskCoverage) >= 该值 才入候选;
; ghost 抑制也用同一口径同一阈值(R-MERGE). default=0.30
iou_threshold=0.30
; F13 触发条件 A:连续 missCount >= miss_frames_x 即视为离开视野. default=2
miss_frames_x=2
; F13 触发条件 B:updateCount >= update_frames_y 即"早派发"避免压线遗漏.
; default=10
update_frames_y=10
; ghost 池清扫距离 mm. trailing edge 越过分拣线 + 该距离才丢弃 ghost,
; 防止"已派发但还在抑制窗口内"误新建 track. default=200
dispatched_pool_clear_distance_mm=200
; belt 系栅格 mask 的物理像素分辨率 mm/px (1px = N mm). 越小越精准内存越大.
; default=2 (每像素 2mm)
mask_raster_mm_per_px=2
; BoardWorker::onValveTick 周期 ms. 影响阀打开时刻精度上限. default=5
tick_interval_ms=5


; -----------------------------------------------------------------------------
; [belt]  皮带速度与编码器 (消费方:BoardWorker;Tracker/Dispatcher 兜底)
; -----------------------------------------------------------------------------
[belt]
; 标称皮带速度 m/s. 仅在 BoardWorker 还没拿到首个有效 SpeedSample 时兜底.
; 数值上 m/s == mm/ms. default=0.5
nominal_speed_m_s=0.5
; 编码器 raw -> 线速度的转换系数 (单位 m/min/raw). raw 是板卡内部已采样好
; 的"瞬时转速代理"(不是脉冲计数也不是窗口增量):
;   speed_m_per_min = raw * encoder_raw_to_m_per_min
;   speed_mm_per_ms = speed_m_per_min / 60
; 与 master 分支硬编码一致;default=0.502
encoder_raw_to_m_per_min=0.502
; 编码器请求帧周期 ms. BoardWorker::onEncoderTick 与 session 解耦,
; Idle 态也持续轮询(UI 持续显示速度). default=500
encoder_request_interval_ms=500


; -----------------------------------------------------------------------------
; [sorter]  分拣方式与几何距离
; (消费方:TrackerWorker 的分拣线计算 / Dispatcher 分流)
; -----------------------------------------------------------------------------
[sorter]
; 分拣方式: valve(默认) | arm.
;   valve: Dispatcher 走 computePulses + enqueuePulses;
;   arm  : Dispatcher 走 dispatchArmStub 写 CSV(本期仅日志,不下发硬件指令).
mode=valve
; arm 模式下臂末端距相机视野最近边缘的物理距离 mm. default=500
arm_distance_mm=500
; valve 模式下喷阀末端距相机视野最近边缘的物理距离 mm.
; TrackerWorker::valveLineYb() 与 Dispatcher::computePulses 都依赖此值;
; default=800
valve_distance_mm=800


; -----------------------------------------------------------------------------
; [valve]  喷阀阵列布线 + 喷阀控制策略
; (消费方:Dispatcher::computePulses)
; -----------------------------------------------------------------------------
[valve]
; 通道总数. = boards * channels_per_board (本 INI 中 8*9=72). default=72
total_channels=72
; 控制板数. 每块板的物理 ID 在 RS485 总线上唯一. default=8
boards=8
; 每块板的通道数. default=9
channels_per_board=9
; 阵列横向覆盖物理范围 mm 的左/右端. 喷阀通道 i 对应的 belt-x 区间是
;   [x_min + i*step, x_min + (i+1)*step]
; 其中 step = (x_max - x_min) / total_channels. default=0 / 560
x_min_mm=0
x_max_mm=560
; 头部留白比例 [0..1]. computePulses 从 mask 前沿向后累积像素,直到累积
; 非零像素 >= totalArea * head_skip_ratio 才开始投影,避免对极薄前沿
; 的"误开"导致瞬开瞬关. default=0.125 (12.5%)
head_skip_ratio=0.125
; 每个 ValvePulse 的开启时长 ms;同时也是滚动投影的步长 ms. default=50
open_duration_ms=50
; 同板上下两条 pulse 的最小命令间隔 ms. 间距小于该值则与前条 pulse 合并
; (位图 OR、tClose 取最大). default=50
min_cmd_interval_ms=50
; 速度突变重算阈值 (百分比 %). |Δspeed|/oldSpeed > 该值 才触发
; cancel + recompute + enqueue 整体重算. default=20 (=20%)
speed_recalc_threshold_pct=20


; -----------------------------------------------------------------------------
; [arm_stub]  机械臂坐标标定 stub (消费方:Dispatcher::dispatchArmStub)
; bbox 重心 (xb, yb) -> 本地 armA / armB 坐标:
;   armA.x = a_x_sign * (xb - a_origin_x_mm)
;   armA.y = a_y_sign * (yb - a_origin_y_mm)
;   armB.x = b_x_sign * (xb - b_origin_x_mm)
;   armB.y = b_y_sign * (yb - b_origin_y_mm)
; 仅日志 + CSV,本期不真正下发硬件指令。
; -----------------------------------------------------------------------------
[arm_stub]
; armA 原点 X (mm)
a_origin_x_mm=0
; armA 原点 Y (mm)
a_origin_y_mm=0
; armA X 方向极性: +1 或 -1
a_x_sign=1
; armA Y 方向极性: +1 或 -1
a_y_sign=1
; armB 原点 X (mm)
b_origin_x_mm=0
; armB 原点 Y (mm)
b_origin_y_mm=0
; armB X 方向极性: +1 或 -1
b_x_sign=1
; armB Y 方向极性: +1 或 -1
b_y_sign=1


; -----------------------------------------------------------------------------
; [persistence]  落盘策略 (F16,消费方:CameraWorker / YoloWorker / Dispatcher)
; -----------------------------------------------------------------------------
[persistence]
; 是否保存原始相机帧. 开启后按 raw_sample_ratio 抽样落盘到 save_dir.
; default=false
save_raw=false
; 原始帧抽样比例 [0..1]. 0.1 = 每 10 帧落 1 张,降磁盘占用. default=0.1
raw_sample_ratio=0.1
; 是否保存 YOLO 后处理后的 result_*.jpg(带 mask/box/label overlay).
; default=false
save_result=false
; 落盘根目录(包括 raw 与 result). 路径不存在时 worker 会按需 mkdir -p.
; default=/data/captures
save_dir=/data/captures
; arm 模式下的派发 CSV. 每次 dispatchArmStub 追加一行;valve 模式下不打开
; 此文件,因此不会出现 "无法打开 csv" 类错误日志.
; default=/data/logs/arm_stub.csv
arm_stub_csv=/data/logs/arm_stub.csv
